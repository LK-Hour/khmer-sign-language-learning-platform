---
config:
  layout: elk
---
erDiagram
	direction TB
	users {
		UUID id PK ""  
		VARCHAR username UK ""  
		VARCHAR email  "nullable — Facebook/Telegram may not provide"  
		VARCHAR password_hash  "nullable — OAuth users have no password"  
		VARCHAR display_name  ""  
		TEXT avatar_url  "profile picture URL from OAuth provider"  
		VARCHAR account_type  "student | admin"  
		VARCHAR auth_provider  "email | google | facebook | telegram"  
		BOOLEAN is_guest  ""  
		BOOLEAN is_active  ""  
		TIMESTAMP last_login_at  ""  
		TIMESTAMP created_at  ""  
		TIMESTAMP updated_at  ""  
	}

	user_oauth_providers {
		UUID id PK ""  
		UUID user_id FK ""  
		VARCHAR provider  "google|facebook|telegram — UK(provider, provider_user_id)"  
		VARCHAR provider_user_id UK ""  
		VARCHAR provider_email  "nullable"  
		TEXT provider_avatar_url  ""  
		TEXT access_token_encrypted  "AES encrypted — must be retrievable"  
		TEXT refresh_token_encrypted  "AES encrypted"  
		TIMESTAMP token_expires_at  ""  
		TIMESTAMP created_at  ""  
		TIMESTAMP updated_at  ""  
	}

	user_lesson_progress {
		UUID id PK ""  
		UUID user_id FK "UK(user_id, track_type, lesson_id)"  
		VARCHAR track_type  "sign | finger"  
		BIGINT lesson_id  "app-layer FK via track_type"  
		BOOLEAN is_completed  ""  
		BOOLEAN is_locked  ""  
		NUMERIC peakest_accuracy  ""  
		INTEGER attempts  ""  
		INTEGER total_time_spent  "seconds"  
		TIMESTAMP started_at  ""  
		TIMESTAMP completed_at  ""  
		TIMESTAMP last_accessed_at  ""  
		TIMESTAMP created_at  ""  
		TIMESTAMP updated_at  ""  
	}

	user_exercise_results {
		UUID id PK ""  
		UUID user_id FK ""  
		VARCHAR track_type  "sign|finger"  
		BIGINT exercise_id  "app-layer FK via track_type"  
		UUID progress_id FK ""  
		TEXT selected_answer  ""  
		BOOLEAN is_correct  ""  
		INTEGER time_taken  "seconds"  
		INTEGER attempt_number  ""  
		TIMESTAMP created_at  ""  
	}

	sign_lesson_words {
		BIGINT id PK ""  
		BIGINT lesson_id FK "UK(lesson_id, word_id)"  
		BIGINT word_id FK ""  
		INTEGER order_index  ""  
		TIMESTAMP created_at  ""  
	}

	sign_exercises {
		BIGINT id PK ""  
		BIGINT lesson_id FK ""  
		TEXT question_en  ""  
		TEXT question_kh  ""  
		VARCHAR exercise_type  "multiple_choice|free_form|video_select|matching"  
		BIGINT media_id FK "nullable — question media"  
		VARCHAR correct_answer  "for free_form"  
		TEXT explanation_en  ""  
		TEXT explanation_kh  ""  
		INTEGER points  ""  
		INTEGER order_index  ""  
		TIMESTAMP created_at  ""  
		TIMESTAMP updated_at  ""  
	}

	sign_exercise_options {
		BIGINT id PK ""  
		BIGINT exercise_id FK ""  
		VARCHAR option_text_en  ""  
		VARCHAR option_text_kh  ""  
		BIGINT media_id FK "nullable — for video_select"  
		BOOLEAN is_correct  ""  
		INTEGER order_index  ""  
		TIMESTAMP created_at  ""  
	}

	sign_practice_sessions {
		BIGINT id PK ""  
		UUID user_id FK ""  
		BIGINT lesson_id FK ""  
		BIGINT[] word_id FK ""  
		TIMESTAMP started_at  ""  
		TIMESTAMP ended_at  ""  
		INTEGER duration  "seconds"  
		NUMERIC average_accuracy  ""  
		NUMERIC peak_accuracy  ""  
		INTEGER keyframe_count  ""  
		BOOLEAN is_completed  ""  
		TIMESTAMP created_at  ""  
	}

	finger_lesson_letters {
		BIGINT id PK ""  
		BIGINT lesson_id FK "UK(lesson_id, letter_id)"  
