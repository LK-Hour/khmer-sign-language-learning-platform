---
config:
  layout: elk
---
erDiagram
	direction TB

	users {
		UUID id PK ""
		VARCHAR username UK ""
		VARCHAR email "nullable"
		VARCHAR password_hash "nullable"
		VARCHAR display_name ""
		TEXT avatar_url ""
		VARCHAR account_type "ENUM: student | admin"
		VARCHAR auth_provider "ENUM: email | google | facebook | telegram"
		BOOLEAN is_guest "derivable but kept for quick queries"
		BOOLEAN is_active ""
		TIMESTAMPTZ last_login_at ""
		TIMESTAMPTZ created_at ""
		TIMESTAMPTZ updated_at ""
	}

	user_oauth_providers {
		UUID id PK ""
		UUID user_id FK ""
		VARCHAR provider "ENUM: google|facebook|telegram"
		VARCHAR provider_user_id ""
		VARCHAR provider_email "nullable"
		TEXT provider_avatar_url ""
		TEXT access_token_encrypted ""
		TEXT refresh_token_encrypted ""
		TIMESTAMPTZ token_expires_at ""
		TIMESTAMPTZ created_at ""
		TIMESTAMPTZ updated_at ""
		%% UK(provider, provider_user_id)
	}

	user_sessions {
		UUID id PK ""
		UUID user_id FK ""
		VARCHAR token_hash UK ""
		VARCHAR refresh_token_hash UK ""
		INET ip_address ""
		VARCHAR device_id "nullable"
		TEXT user_agent ""
		BOOLEAN is_active ""
		TIMESTAMPTZ expires_at ""
		TIMESTAMPTZ refresh_expires_at ""
		TIMESTAMPTZ last_used_at ""
		TIMESTAMPTZ created_at ""
		TIMESTAMPTZ revoked_at "NULL = active"
	}

	sign_user_lesson_progress {
		UUID id PK ""
		UUID user_id FK "UK(user_id, sign_lesson_id)"
		BIGINT sign_lesson_id FK ""
		BOOLEAN is_completed ""
		BOOLEAN is_locked ""
		NUMERIC(5,2) peak_accuracy "CHECK (BETWEEN 0 AND 100)"
		INTEGER attempts "CHECK (>= 0)"
		INTEGER total_time_spent "seconds"
		TIMESTAMPTZ started_at ""
		TIMESTAMPTZ completed_at ""
		TIMESTAMPTZ last_accessed_at ""
		TIMESTAMPTZ created_at ""
		TIMESTAMPTZ updated_at ""
	}

	finger_user_lesson_progress {
		UUID id PK ""
		UUID user_id FK "UK(user_id, finger_lesson_id)"
		BIGINT finger_lesson_id FK ""
		BOOLEAN is_completed ""
		BOOLEAN is_locked ""
		NUMERIC(5,2) peak_accuracy "CHECK (BETWEEN 0 AND 100)"
		INTEGER attempts "CHECK (>= 0)"
		INTEGER total_time_spent "seconds"
		TIMESTAMPTZ started_at ""
		TIMESTAMPTZ completed_at ""
		TIMESTAMPTZ last_accessed_at ""
		TIMESTAMPTZ created_at ""
		TIMESTAMPTZ updated_at ""
	}

	sign_user_exercise_results {
		UUID id PK ""
		UUID user_id FK ""
		BIGINT sign_exercise_id FK ""
		UUID progress_id FK "-> sign_user_lesson_progress"
		BIGINT selected_option_id FK "nullable — for multiple choice"
		TEXT selected_answer "nullable — for free_form"
		BOOLEAN is_correct ""
		INTEGER time_taken "seconds, CHECK (>= 0)"
		INTEGER attempt_number "CHECK (>= 0)"
		TIMESTAMPTZ created_at ""
	}

	finger_user_exercise_results {
		UUID id PK ""
		UUID user_id FK ""
		BIGINT finger_exercise_id FK ""
		UUID progress_id FK "-> finger_user_lesson_progress"
		BIGINT selected_option_id FK "nullable — for multiple choice"
		TEXT selected_answer "nullable — for free_form"
		BOOLEAN is_correct ""
		INTEGER time_taken "seconds, CHECK (>= 0)"
		INTEGER attempt_number "CHECK (>= 0)"
		TIMESTAMPTZ created_at ""
	}

	medias {
		BIGINT id PK ""  
		VARCHAR media_type  "video | gif | image"  
		TEXT file_url  ""  
		TIMESTAMP created_at  ""  
		TIMESTAMP updated_at  ""  
	}

